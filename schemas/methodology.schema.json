{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://learntothink-app.github.io/l2t-protocol/schemas/methodology.schema.json",
  "title": "L2T Methodology",
  "description": "Top-level container that bundles a knowledge hypergraph with the methodology's pedagogical primitives, custom invariants, reliability function and metric configuration.",
  "type": "object",
  "required": [
    "protocolVersion",
    "methodologyId",
    "methodologyVersion",
    "title",
    "domain",
    "knowledgeHypergraph"
  ],
  "additionalProperties": false,
  "properties": {
    "protocolVersion": {
      "$ref": "definitions.schema.json#/$defs/SemanticVersion",
      "description": "L2T protocol version this methodology targets."
    },
    "methodologyId": { "$ref": "definitions.schema.json#/$defs/Identifier" },
    "methodologyVersion": { "$ref": "definitions.schema.json#/$defs/SemanticVersion" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "authors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "affiliation": { "type": "string" },
          "email": { "type": "string", "format": "email" }
        }
      }
    },
    "domain": {
      "type": "string",
      "description": "Subject domain (e.g. 'informatics', 'mathematics', 'physics')."
    },
    "audience": {
      "type": "string",
      "description": "Target audience descriptor (e.g. 'high_school', 'first_year_undergraduate')."
    },
    "language": {
      "type": "string",
      "description": "BCP 47 tag of the natural language used in user-facing fields (statementTex, hint.text, …)."
    },
    "knowledgeHypergraph": { "$ref": "knowledge-hypergraph.schema.json" },
    "microTheories": {
      "type": "array",
      "items": { "$ref": "microtheory.schema.json" }
    },
    "tasks": {
      "type": "array",
      "items": { "$ref": "task.schema.json" }
    },
    "drills": {
      "type": "array",
      "items": { "$ref": "task.schema.json" },
      "description": "Drills share the Task schema; they are distinguished by their referenced vertex type."
    },
    "probes": {
      "type": "array",
      "items": { "$ref": "probe.schema.json" }
    },
    "thinkingTools": {
      "type": "array",
      "items": { "$ref": "definitions.schema.json#/$defs/ThinkingTool" }
    },
    "thinkingSystems": {
      "type": "array",
      "items": { "$ref": "definitions.schema.json#/$defs/ThinkingSystem" }
    },
    "customInvariants": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "formula"],
        "additionalProperties": false,
        "properties": {
          "id": { "$ref": "definitions.schema.json#/$defs/Identifier" },
          "label": { "type": "string" },
          "formula": {
            "type": "string",
            "description": "Past-LTL formula in protocol-canonical syntax."
          },
          "atomicPredicates": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "reliabilityFunction": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "coefficients"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "heuristic" },
            "coefficients": {
              "type": "object",
              "required": ["alpha", "beta", "gamma", "delta"],
              "additionalProperties": false,
              "properties": {
                "alpha": { "type": "number", "minimum": 0 },
                "beta":  { "type": "number", "minimum": 0 },
                "gamma": { "type": "number", "minimum": 0 },
                "delta": { "type": "number", "minimum": 0 }
              }
            },
            "qMin": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.05 }
          }
        },
        {
          "type": "object",
          "required": ["kind", "modelRef"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "classifier" },
            "modelRef": {
              "type": "string",
              "description": "URI of the trained reliability classifier artifact."
            },
            "qMin": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.05 }
          }
        }
      ]
    },
    "metricsConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kappa": { "type": "number", "minimum": 0, "default": 0.5 },
        "qLow": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.3 },
        "retentionDelaysDays": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1 },
          "default": [1, 3, 7, 14]
        }
      }
    }
  }
}
